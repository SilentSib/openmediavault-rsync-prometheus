#!/bin/sh
set -e

case "$1" in
    install|upgrade)
        # Remove the Salt file cache for this state. Salt caches SLS files
        # under /var/cache/salt/minion/files/base/ and will serve the cached
        # copy even after the source file on disk has been replaced by dpkg.
        rm -rf /var/cache/salt/minion/files/base/omv/deploy/rsync-prometheus

        # Also remove the compiled state cache
        rm -rf /var/cache/salt/minion/extmods/

        # Remove the state directory itself so dpkg lays down a clean copy
        rm -rf /srv/salt/omv/deploy/rsync-prometheus
        ;;
esac

#DEBHELPER#
exit 0
