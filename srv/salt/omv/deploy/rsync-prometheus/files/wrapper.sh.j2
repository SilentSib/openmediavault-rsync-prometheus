#!/bin/sh
# Auto-generated by openmediavault-rsync-prometheus — do not edit.
# Job: {{ job.uuid }}

# No set -e — we must always reach the metric push regardless of rsync outcome.

JOB_UUID="{{ job.uuid }}"
PUSHGATEWAY_URL="{{ config.pushgateway_url | trim('/') }}"
JOB_LABEL="{{ (config.job_label_prefix ~ '_' ~ job.uuid) | replace('-', '_') }}"
INSTANCE="{{ config.instance if config.instance else grains['host'] }}"
RSYNC_SCRIPT="{{ cron_script_dir }}/rsync-{{ job.uuid }}"
TLS_VERIFY="{{ config.tls_verify | to_bool }}"
USERNAME="{{ config.username }}"
PASSWORD="{{ config.password }}"
{% if job.comment is defined and job.comment %}
JOB_NAME="{{ job.comment | replace('"', '\\"') }}"
{% else %}
JOB_NAME="{{ job.uuid }}"
{% endif %}

# ── Run the actual rsync script ──────────────────────────────────────────────
# OMV's rsync script always exits 0 even on failure — it handles its own
# error reporting via syslog/email. We detect failure by checking stdout
# for the exact message OMV emits: "The synchronisation failed."
START_TIME=$(date +%s%3N)
RSYNC_OUTPUT=$("$RSYNC_SCRIPT" 2>&1)
RAW_EXIT=$?
END_TIME=$(date +%s%3N)

DURATION_MS=$(( END_TIME - START_TIME ))
TIMESTAMP=$(date +%s)

# Primary: match OMV's exact failure string (case-insensitive for safety).
# Secondary: honour a non-zero exit in case future OMV versions propagate it.
if echo "$RSYNC_OUTPUT" | grep -qiF "synchronisation failed"; then
    EXIT_CODE=1
elif [ "$RAW_EXIT" -ne 0 ]; then
    EXIT_CODE=$RAW_EXIT
else
    EXIT_CODE=0
fi

SUCCESS=$([ "$EXIT_CODE" -eq 0 ] && echo 1 || echo 0)

# ── Build metric payload ─────────────────────────────────────────────────────
METRICS=$(printf '%s\n' \
  "# HELP omv_rsync_job_success Whether the last rsync job succeeded (1=success 0=failure)." \
  "# TYPE omv_rsync_job_success gauge" \
  "omv_rsync_job_success{job=\"${JOB_LABEL}\",instance=\"${INSTANCE}\",name=\"${JOB_NAME}\"} ${SUCCESS}" \
  "# HELP omv_rsync_job_last_exit_code Exit code of the last rsync run." \
  "# TYPE omv_rsync_job_last_exit_code gauge" \
  "omv_rsync_job_last_exit_code{job=\"${JOB_LABEL}\",instance=\"${INSTANCE}\",name=\"${JOB_NAME}\"} ${EXIT_CODE}" \
  "# HELP omv_rsync_job_duration_ms Duration of the last rsync run in milliseconds." \
  "# TYPE omv_rsync_job_duration_ms gauge" \
  "omv_rsync_job_duration_ms{job=\"${JOB_LABEL}\",instance=\"${INSTANCE}\",name=\"${JOB_NAME}\"} ${DURATION_MS}" \
  "# HELP omv_rsync_job_last_run_timestamp_seconds Unix timestamp of the last run completion." \
  "# TYPE omv_rsync_job_last_run_timestamp_seconds gauge" \
  "omv_rsync_job_last_run_timestamp_seconds{job=\"${JOB_LABEL}\",instance=\"${INSTANCE}\",name=\"${JOB_NAME}\"} ${TIMESTAMP}" \
)

# ── Build curl arguments ─────────────────────────────────────────────────────
CURL_ARGS="--silent --show-error --max-time 10 --request POST"
if [ "$TLS_VERIFY" = "False" ]; then
  CURL_ARGS="$CURL_ARGS --insecure"
fi
if [ -n "$USERNAME" ]; then
  CURL_ARGS="$CURL_ARGS --user ${USERNAME}:${PASSWORD}"
fi

# ── Push to Pushgateway ──────────────────────────────────────────────────────
PUSH_OUTPUT=$(echo "$METRICS" | curl \
  $CURL_ARGS \
  --data-binary @- \
  "${PUSHGATEWAY_URL}/metrics/job/${JOB_LABEL}/instance/${INSTANCE}" 2>&1)
PUSH_EXIT=$?

if [ $PUSH_EXIT -eq 0 ]; then
  echo "$(date '+%Y-%m-%d %H:%M:%S') $([ "$SUCCESS" = "1" ] && echo OK || echo FAIL) job=${JOB_LABEL} name=${JOB_NAME} rsync_exit=${EXIT_CODE} duration=${DURATION_MS}ms" \
    >> /var/log/omv-rsync-prometheus.log
else
  echo "$(date '+%Y-%m-%d %H:%M:%S') PUSH_FAIL job=${JOB_LABEL} name=${JOB_NAME} curl_exit=${PUSH_EXIT} output=${PUSH_OUTPUT}" \
    >> /var/log/omv-rsync-prometheus.log
fi

# Exit 0 to match OMV's own behaviour — cron/mail handling is OMV's job.
exit 0
